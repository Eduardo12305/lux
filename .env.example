# .env.example — Lux v1.0.0
# Copie para .env e ajuste conforme seu ambiente

# ── Hardware ──────────────────────────────────────────────
LUX_VRAM_BUDGET_GB=14.5
LUX_GPU_BACKEND=rocm

# ── Modelos ───────────────────────────────────────────────
LUX_MAIN_MODEL_PATH=/models/Qwen3-14B-Instruct-Q4_K_M.gguf
LUX_AUX_MODEL_PATH=/models/Qwen3-1.7B-Instruct-Q4_K_M.gguf
LUX_WHISPER_MODEL=small
LUX_PIPER_VOICE=pt_BR-faber-medium
LUX_LLAMA_MAIN_URL=http://127.0.0.1:8080
LUX_LLAMA_AUX_URL=http://127.0.0.1:8081

# ── Omni (MiniCPM-o 4.5 unificado) ────────────────────────
LUX_OMNI_MODEL_PATH=~/.lux/models/minicpm-o-4_5-gguf/MiniCPM-o-4_5-Q4_K_M.gguf
LUX_OMNI_BINARY_PATH=llama-omni-cli
LUX_OMNI_REF_AUDIO_PATH=
LUX_OMNI_GFX_OVERRIDE=12.0.1
LUX_OMNI_VRAM_LAYERS=-1

# ── Serviços ──────────────────────────────────────────────
LUX_QDRANT_URL=http://localhost:6333
LUX_REDIS_URL=redis://localhost:6379

# ── Sessão e Contexto ─────────────────────────────────────
LUX_CTX_SIZE=8192
LUX_PARALLEL_SLOTS_MAIN=2
LUX_PARALLEL_SLOTS_AUX=4
LUX_MAX_ITERATIONS=50
LUX_COMPRESSION_THRESHOLD=0.50
LUX_PROTECT_LAST_N=20

# ── Memória ───────────────────────────────────────────────
LUX_MEMORY_MD_LIMIT=2200
LUX_USER_MD_LIMIT=1375

# ── Skills ────────────────────────────────────────────────
LUX_AUTO_CREATE_SKILLS=true
LUX_SKILL_CREATION_THRESHOLD=5

# ── Wake Word ──────────────────────────────────────────────
LUX_WAKE_WORD=arkana
LUX_WAKEWORD_MODEL_DIR=~/.lux/models/wakeword
LUX_WAKEWORD_THRESHOLD=0.5
LUX_WAKEWORD_COOLDOWN_S=2.0

# ── Proatividade ──────────────────────────────────────────
LUX_PROACTIVITY_ENABLED=true
LUX_PROACTIVITY_POLL_INTERVAL=30

# ── Segurança ─────────────────────────────────────────────
LUX_JWT_SECRET=
LUX_SESSION_EXPIRE_HOURS=24
LUX_ENABLE_DANGEROUS_TOOLS=false

# ── Processos Gerenciados ─────────────────────────────────
LUX_MANAGED_PROCESSES=true
LUX_LLAMA_SERVER_BIN=llama-server

# ── Interfaces ────────────────────────────────────────────
LUX_GRADIO_ENABLED=false
LUX_GRADIO_PORT=7860
LUX_ACP_ENABLED=false
LUX_ACP_PORT=3284

# ── Gateway (opcional) ────────────────────────────────────
LUX_TELEGRAM_TOKEN=
LUX_DISCORD_TOKEN=
LUX_DISCORD_CHANNEL_IDS=
LUX_SLACK_BOT_TOKEN=
LUX_SLACK_APP_TOKEN=
LUX_EMAIL_IMAP_HOST=
LUX_EMAIL_SMTP_HOST=
LUX_EMAIL_ADDRESS=
LUX_EMAIL_PASSWORD=
LUX_SEARXNG_URL=http://localhost:8888

# ── Diretórios Monitorados (Módulo 1 - File Watcher) ────────
LUX_WATCH_DIRS=/home/luis-eduardo/Documentos
LUX_REINDEX_INTERVAL=30
LUX_ACCEPTED_EXTENSIONS=.md,.txt,.py,.json,.yaml,.yml,.toml,.cfg,.ini,.env,.sh,.js,.ts,.html,.css,.rs,.go,.java,.c,.cpp,.h
LUX_DIR_MAX_DEPTH=3
LUX_FILE_WATCHER_ENABLED=true

# ── E-mail Inteligente (Módulo 2 - Email Classifier) ────────
LUX_EMAIL_PROVIDER=imap
LUX_EMAIL_FETCH_LIMIT=50
LUX_EMAIL_INTERESTS=
LUX_EMAIL_CLASSIFIER_ENABLED=false

# ── Workflow Engine (Módulo 3) ─────────────────────────────
LUX_WORKFLOWS_ENABLED=true
LUX_WORKFLOW_DIR=~/.lux/workflows

LUX_ENABLE_OMNI=true
